# Mooncci server environment example.
# Copy this file to .env and fill real values on the server.
# Never commit or package real secrets.

NODE_ENV=production
PORT=3001
SITE_URL=https://mooncci.site

DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name
DB_CONNECTION_LIMIT=20

JWT_SECRET=replace_with_a_long_random_secret

COOKIE_SECURE=true
COOKIE_DOMAIN=.mooncci.site
CORS_ORIGINS=https://mooncci.site,https://www.mooncci.site

MAIL_ENABLED=false
SMTP_HOST=
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
COMMENT_NOTIFY_TO=

CUSTOM_MAIL_DAILY_LIMIT=20
